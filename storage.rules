
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userAccessPath(companyId) {
      return /databases/(default)/documents/users/$(request.auth.uid)/userAccess/$(companyId);
    }

    function hasCompanyAccess(companyId) {
      return signedIn()
        && companyId is string
        && firestore.exists(userAccessPath(companyId));
    }

    function isCompanyAdmin(companyId) {
      return hasCompanyAccess(companyId)
        && firestore.get(userAccessPath(companyId)).data.roleName in ["Owner", "Admin", "Manager"];
    }

    function companyRolePath(companyId) {
      return /databases/(default)/documents/companies/$(companyId)/roles/$(firestore.get(userAccessPath(companyId)).data.roleId);
    }

    function hasCompanyRolePermission(companyId, permissionId) {
      return hasCompanyAccess(companyId)
        && firestore.get(userAccessPath(companyId)).data.roleId is string
        && firestore.exists(companyRolePath(companyId))
        && (
          !(firestore.get(companyRolePath(companyId)).data.permissionIdList is list)
          || permissionId in firestore.get(companyRolePath(companyId)).data.permissionIdList
        );
    }

    function canReadPerformanceAttachment(companyId) {
      return isCompanyAdmin(companyId) || hasCompanyRolePermission(companyId, "260");
    }

    function canWritePerformanceAttachment(companyId) {
      return isCompanyAdmin(companyId) || hasCompanyRolePermission(companyId, "264");
    }

    function canReadRepairRequestAttachment(companyId) {
      return hasCompanyAccess(companyId);
    }

    function canWriteRepairRequestAttachment(companyId) {
      return hasCompanyAccess(companyId);
    }

    function isRepairRequestImageUpload() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    function isCompanyImageUpload() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    match /users/{userId}/profile/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /repair-requests/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /repair-request/{repairRequestId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && isRepairRequestImageUpload();
    }

    match /companies/{companyId}/repairRequests/{repairRequestId}/{allPaths=**} {
      allow read: if canReadRepairRequestAttachment(companyId);
      allow write: if canWriteRepairRequestAttachment(companyId) && isRepairRequestImageUpload();
    }

    match /companies/{companyId}/serviceLocations/{serviceLocationId}/{allPaths=**} {
      allow read: if hasCompanyAccess(companyId);
      allow write: if hasCompanyAccess(companyId) && isCompanyImageUpload();
    }

    match /companies/{companyId}/bodiesOfWater/{bodyOfWaterId}/{allPaths=**} {
      allow read: if hasCompanyAccess(companyId);
      allow write: if hasCompanyAccess(companyId) && isCompanyImageUpload();
    }

    match /companies/{companyId}/equipment/{equipmentId}/{allPaths=**} {
      allow read: if hasCompanyAccess(companyId);
      allow write: if hasCompanyAccess(companyId) && isCompanyImageUpload();
    }

    match /companies/{companyId}/serviceStops/{serviceStopId}/{allPaths=**} {
      allow read: if hasCompanyAccess(companyId);
      allow write: if hasCompanyAccess(companyId) && isCompanyImageUpload();
    }

    match /companies/{companyId}/receipts/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /companies/{companyId}/performanceReviews/{companyUserId}/internal/{allPaths=**} {
      allow read: if canReadPerformanceAttachment(companyId);
      allow write: if canWritePerformanceAttachment(companyId);
    }

    match /companies/{companyId}/performanceReviews/{companyUserId}/shared/{allPaths=**} {
      allow read: if hasCompanyAccess(companyId);
      allow write: if canWritePerformanceAttachment(companyId);
    }
  }
}
