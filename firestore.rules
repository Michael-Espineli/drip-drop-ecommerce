rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isDripDropAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == "Admin";
    }

    function appLaunchEnabled() {
      return get(/databases/$(database)/documents/featureFlags/feature_flag_000).data.enabled == true;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userAccessPath(companyId) {
      return /databases/$(database)/documents/users/$(request.auth.uid)/userAccess/$(companyId);
    }

    function hasCompanyAccess(companyId) {
      return signedIn()
        && companyId is string
        && exists(userAccessPath(companyId));
    }

    function isCompanyAdmin(companyId) {
      return hasCompanyAccess(companyId)
        && get(userAccessPath(companyId)).data.roleName in ["Owner", "Admin", "Manager"];
    }

    function isPersonalOrCompanyData(data) {
      return signedIn()
        && (
          (data.userId is string && data.userId == request.auth.uid)
          || (data.ownerId is string && data.ownerId == request.auth.uid)
          || (data.clientId is string && data.clientId == request.auth.uid)
          || (data.customerUserId is string && data.customerUserId == request.auth.uid)
          || (data.companyId is string && hasCompanyAccess(data.companyId))
          || (data.linkedCompanyId is string && hasCompanyAccess(data.linkedCompanyId))
          || (data.senderId is string && hasCompanyAccess(data.senderId))
          || (data.receiverId is string && hasCompanyAccess(data.receiverId))
        );
    }

    function emailMatchesSignedInUser(data) {
      return signedIn()
        && request.auth.token.email is string
        && (
          (data.email is string && data.email == request.auth.token.email)
          || (data.customerEmail is string && data.customerEmail == request.auth.token.email)
          || (data.billingEmail is string && data.billingEmail == request.auth.token.email)
        );
    }

    function hasLinkedSalesCustomerUser(data) {
      return data.customerUserId is string && data.customerUserId.size() > 0;
    }

    function canReadSalesRecord(data) {
      return signedIn()
        && (
          (data.companyId is string && hasCompanyAccess(data.companyId))
          || (data.customerUserId is string && data.customerUserId == request.auth.uid)
          || (!hasLinkedSalesCustomerUser(data) && emailMatchesSignedInUser(data))
        );
    }

    function canCompanyWriteSalesRecord(data) {
      return signedIn()
        && data.companyId is string
        && hasCompanyAccess(data.companyId);
    }

    function validProductFeedbackCreate(data) {
      return data.keys().hasOnly([
          "type",
          "typeLabel",
          "audience",
          "title",
          "description",
          "priority",
          "requesterName",
          "requesterEmail",
          "status",
          "source",
          "userId",
          "userEmail",
          "accountType",
          "companyId",
          "companyName",
          "createdAt",
          "updatedAt"
        ])
        && data.keys().hasAll(["type", "title", "description", "status", "source", "createdAt", "updatedAt"])
        && data.type in ["bug", "feature"]
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 200
        && data.description is string
        && data.description.size() > 0
        && data.description.size() <= 5000
        && data.status == "New"
        && data.source == "footer"
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function validContactMessageCreate(data) {
      return data.keys().hasOnly([
          "name",
          "email",
          "companyName",
          "subject",
          "message",
          "audience",
          "status",
          "source",
          "userId",
          "userEmail",
          "accountType",
          "companyId",
          "createdAt",
          "updatedAt"
        ])
        && data.keys().hasAll(["name", "email", "message", "status", "source", "createdAt", "updatedAt"])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 160
        && data.email is string
        && data.email.size() > 0
        && data.email.size() <= 320
        && data.message is string
        && data.message.size() > 0
        && data.message.size() <= 5000
        && data.status == "New"
        && data.source in ["contact-page", "footer"]
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function chatParticipant(data) {
      return signedIn()
        && data.participantIds is list
        && request.auth.uid in data.participantIds;
    }

    function companyChatParticipant(data) {
      return signedIn()
        && (
          (data.companyId is string && hasCompanyAccess(data.companyId))
          || (data.senderCompanyId is string && hasCompanyAccess(data.senderCompanyId))
          || (data.receiverCompanyId is string && hasCompanyAccess(data.receiverCompanyId))
        );
    }

    function canReadChatData(data) {
      return chatParticipant(data) || companyChatParticipant(data);
    }

    function chatPath(chatId) {
      return /databases/$(database)/documents/chats/$(chatId);
    }

    function canReadChatById(chatId) {
      return signedIn()
        && chatId is string
        && exists(chatPath(chatId))
        && canReadChatData(get(chatPath(chatId)).data);
    }

    function canReadChatByIdAfter(chatId) {
      return signedIn()
        && chatId is string
        && existsAfter(chatPath(chatId))
        && canReadChatData(getAfter(chatPath(chatId)).data);
    }

    match /users/{userId} {
      allow create: if isSelf(userId)
        && request.resource.data.id == request.auth.uid;
      allow read, update: if isSelf(userId);
      allow delete: if false;

      match /userAccess/{accessId} {
        allow read: if isSelf(userId);
        allow create, update, delete: if false;
      }

      match /savedCompanies/{savedCompanyId} {
        allow read, write: if isSelf(userId);
      }

      match /recentActivity/{activityId} {
        allow read, write: if isSelf(userId);
      }
    }

    match /companies/{companyId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && appLaunchEnabled()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isCompanyAdmin(companyId);
      allow delete: if false;

      match /{document=**} {
        allow read, write: if hasCompanyAccess(companyId);
      }
    }

    match /invites/{inviteId} {
      allow read: if signedIn()
        && (
          (resource.data.email is string && resource.data.email == request.auth.token.email)
          || (resource.data.userId is string && resource.data.userId == request.auth.uid)
          || (resource.data.companyId is string && hasCompanyAccess(resource.data.companyId))
        );
      allow create: if signedIn()
        && request.resource.data.companyId is string
        && hasCompanyAccess(request.resource.data.companyId);
      allow update: if signedIn()
        && resource.data.companyId is string
        && (
          hasCompanyAccess(resource.data.companyId)
          || (
            resource.data.email is string
            && resource.data.email == request.auth.token.email
            && request.resource.data.companyId == resource.data.companyId
            && request.resource.data.roleId == resource.data.roleId
          )
        );
      allow delete: if signedIn()
        && resource.data.companyId is string
        && isCompanyAdmin(resource.data.companyId);
    }

    match /chats/{chatId} {
      allow create: if canReadChatData(request.resource.data);
      allow read, update, delete: if canReadChatData(resource.data);
    }

    match /messages/{messageId} {
      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid
        && (
          canReadChatById(request.resource.data.chatId)
          || canReadChatByIdAfter(request.resource.data.chatId)
        );
      allow read, update, delete: if signedIn()
        && (
          resource.data.senderId == request.auth.uid
          || resource.data.receiverId == request.auth.uid
          || (resource.data.senderCompanyId is string && hasCompanyAccess(resource.data.senderCompanyId))
          || (resource.data.receiverCompanyId is string && hasCompanyAccess(resource.data.receiverCompanyId))
          || canReadChatById(resource.data.chatId)
        );
    }

    match /homeownerServiceRequests/{requestId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /homeownerRepairRequests/{requestId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /customerCompanyRelationships/{relationshipId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /homeownerServiceLocations/{locationId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /homeownerBodiesOfWater/{bodyOfWaterId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /homeownerEquipment/{equipmentId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /homeownerServiceStops/{serviceStopId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /homeownerStopData/{stopDataId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /stopData/{stopDataId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /linkedInvite/{inviteId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /contracts/{contractId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /recurringContracts/{contractId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /laborContracts/{contractId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /serviceStops/{serviceStopId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /workOrders/{workOrderId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /invoices/{invoiceId} {
      allow read, update, delete: if isPersonalOrCompanyData(resource.data);
      allow create: if isPersonalOrCompanyData(request.resource.data);
    }

    match /salesAgreements/{agreementId} {
      allow read: if canReadSalesRecord(resource.data);
      allow create: if canCompanyWriteSalesRecord(request.resource.data);
      allow update, delete: if canCompanyWriteSalesRecord(resource.data);
    }

    match /salesBillingProfiles/{billingProfileId} {
      allow read: if canReadSalesRecord(resource.data);
      allow create: if canCompanyWriteSalesRecord(request.resource.data);
      allow update, delete: if canCompanyWriteSalesRecord(resource.data);
    }

    match /salesBillingSubscriptions/{billingSubscriptionId} {
      allow read: if canReadSalesRecord(resource.data);
      allow create: if canCompanyWriteSalesRecord(request.resource.data);
      allow update, delete: if canCompanyWriteSalesRecord(resource.data);
    }

    match /salesInvoices/{invoiceId} {
      allow read: if canReadSalesRecord(resource.data);
      allow create: if canCompanyWriteSalesRecord(request.resource.data);
      allow update, delete: if canCompanyWriteSalesRecord(resource.data);
    }

    match /salesPayments/{paymentId} {
      allow read: if canReadSalesRecord(resource.data);
      allow create: if canCompanyWriteSalesRecord(request.resource.data);
      allow update, delete: if canCompanyWriteSalesRecord(resource.data);
    }

    match /salesPaymentEvents/{paymentEventId} {
      allow read: if canReadSalesRecord(resource.data);
      allow create, update: if false;
      allow delete: if canCompanyWriteSalesRecord(resource.data);
    }

    match /customerPartApprovals/{approvalId} {
      allow read: if canReadSalesRecord(resource.data);
      allow create: if canCompanyWriteSalesRecord(request.resource.data);
      allow update, delete: if canCompanyWriteSalesRecord(resource.data);
    }

    match /subscriptions/{subscriptionId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /universal/{document=**} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /featureFlags/{flagId} {
      allow get: if flagId == "feature_flag_000" || signedIn();
      allow list: if signedIn();
      allow create, update, delete: if isDripDropAdmin();
    }

    match /productFeedback/{feedbackId} {
      allow create: if validProductFeedbackCreate(request.resource.data) || isDripDropAdmin();
      allow read, update, delete: if isDripDropAdmin();
    }

    match /contactMessages/{messageId} {
      allow create: if validContactMessageCreate(request.resource.data) || isDripDropAdmin();
      allow read, update, delete: if isDripDropAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
